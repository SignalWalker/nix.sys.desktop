#! /usr/bin/env nu

export def get_inputs [] {
  let projects_dir = $env.XDG_PROJECTS_DIR? | default $'($env.HOME)/projects'
  let sys = $'($projects_dir)/nix/sys'
  let hm = $'($projects_dir)/nix/home'
  let nixmod = $'($projects_dir)/nix/mod'
  let nixpkg = $'($projects_dir)/nix/pkg'

  [
    { name: 'homebase', dir: $'($hm)/base' }
    { name: 'homedesk/ashvim', dir: $'($projects_dir)/cfg/neovim' }
    { name: 'homedesk', dir: $'($hm)/desktop' }
    { name: 'sysbase/nginx-vhost-defaults', dir: $'($nixmod)/nginx-vhost-defaults' }
    { name: 'sysbase', dir: $'($sys)/base' }
    { name: 'minecraft', dir: $'($nixpkg)/minecraft-server' }
    { name: 'sysdesk', dir: $'($sys)/desktop' }
  ]
}

export def into_overrides [] {
  each {|input| [ '--override-input' $input.name $input.dir ]} | flatten
}

def main [command?: string, --fmt: string = "lines"] {
  let res = match $command {
    "overrides" | null => {
      get_inputs | into_overrides
    }
    "paths" => {
      get_inputs | get dir
    }
    "table" => {
      get_inputs
    }
    _ => {
      return (error make $'expected overrides or paths, got: ($command)')
    }
  }
  match $fmt {
    "lines" => {
      for line in $res {
        print $line
      }
    }
    "nu" => {
      $res
    }
    _ => {
      error make $'expected lines or nu, got ($fmt)'
    }
  }
}
